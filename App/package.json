{
  "name": "pointer",
  "version": "1.0.0",
  "description": "A modern code editor powered by your local LLM",
  "main": "electron/main.js",
  "scripts": {
    "env": "npx dotenv-wizard",
    "start": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "dev:server": "vite",
    "dev:electron": "electron .",
    "dev": "node start-pointer.js",
    "electron:dev": "concurrently \"yarn start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:start": "electron .",
    "dist": "yarn build && electron-builder --win --mac",
    "dist:win": "yarn build && electron-builder --win",
    "dist:mac": "yarn build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "installer:test": "node installer/test-installation.js",
    "installer:prepare-offline": "node installer/prepare-offline.js",
    "installer:verify": "echo 'Verifying installer components...' && node installer/test-installation.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@types/diff": "^7.0.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "chalk": "4",
    "diff": "^7.0.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.6.2",
    "monaco-editor": "^0.45.0",
    "openai": "^4.81.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "simple-git": "^3.27.0",
    "tcp-port-used": "^1.0.2",
    "uuid": "^11.1.0",
    "windows-debugger": "^1.1.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "dotenv-wizard": "^1.0.4",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.14",
    "wait-on": "^7.2.0",
    "yarn": "^1.22.22"
  },
  "proxy": "http://localhost:1234",
  "build": {
    "appId": "com.pointer",
    "productName": "Pointer",
    "copyright": "Copyright © 2024 PointerIDE",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "backend-node",
        "to": "backend-node",
        "filter": ["**/*", "!node_modules/**"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/logo.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "Install Pointer",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "electron/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "electron/logo.png",
      "uninstallerIcon": "electron/logo.png",
      "installerHeaderIcon": "electron/logo.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pointer",
      "include": "installer/nsis-custom.nsh",
      "installerSidebar": null,
      "license": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/logo.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/setup.js"
    ],
    "extraFiles": [
      {
        "from": "electron/setup.js",
        "to": "resources/app/electron/setup.js"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "PointerIDE",
        "repo": "Pointer"
      }
    ]
  }
}
